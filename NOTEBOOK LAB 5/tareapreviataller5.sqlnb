      ADD (\r

      \    cod_sucursal NUMBER,\r

      \    CONSTRAINT fk_sucursal_prestamo\r

      \        FOREIGN KEY (cod_sucursal)\r

      \        REFERENCES sucursal(cod_sucursal)\r

      );\r

      \r

      \r

      ALTER TABLE cliente\r

      ADD (\r

      \    cod_sucursal NUMBER,\r

      \    CONSTRAINT fk_sucursal_prestamo\r

      \        FOREIGN KEY (cod_sucursal)\r

      \        REFERENCES sucursal(cod_sucursal)\r

      );\r\n"
