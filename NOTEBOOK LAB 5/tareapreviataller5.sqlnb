cells:
  - kind: 1
    value: "# IMPLEMENTAR MODELO FISICO"
    languageId: markdown
  - kind: 1
    value: Script (DDL) que corresponde al levantamiento del modelo fisico
    languageId: markdown
  - kind: 2
    value: "-- POR SI HAY QUE HACER CORRECCIONES\r

      \r

      DROP TABLE prestamo CASCADE CONSTRAINTS;\r

      DROP TABLE telefono_cliente CASCADE CONSTRAINTS;\r

      DROP TABLE email CASCADE CONSTRAINTS;\r

      DROP TABLE cliente CASCADE CONSTRAINTS;\r

      DROP TABLE tipo_prestamo CASCADE CONSTRAINTS;\r

      DROP TABLE profesion CASCADE CONSTRAINTS; \r

      \r

      -- La creacion de la tabla profesion se hace antes que cliente por la
      dependencia de la clave foranea\r

      CREATE TABLE profesion (\r

      \    id_profesion NUMBER PRIMARY KEY,\r

      \    nombre_profesion VARCHAR2(50) NOT NULL UNIQUE\r

      );\r

      --   tipo_prestamo se hace antes que prestamo por la misma razon\r

      CREATE TABLE tipo_prestamo (\r

      \    id_tipo_prestamo NUMBER PRIMARY KEY,\r

      \    nombre_tipo_prestamo VARCHAR2(50) NOT NULL UNIQUE\r

      );\r

      \r

      CREATE TABLE cliente (\r

      \    id_cliente NUMBER PRIMARY KEY,\r

      \    cedula VARCHAR2(25) NOT NULL UNIQUE,\r

      \    nombre VARCHAR2(50) NOT NULL,\r

      \    apellido VARCHAR2(50) NOT NULL,\r

      \    sexo VARCHAR2(2) NOT NULL CHECK (sexo IN ('M', 'F')),\r

      \    fecha_nacimiento DATE NOT NULL,\r

      \    id_profesion NUMBER NOT NULL,\r

      \    CONSTRAINT fk_profesion FOREIGN KEY (id_profesion)\r

      \        REFERENCES profesion(id_profesion)\r

      );\r

      \r

      CREATE TABLE email (\r

      \    id_email NUMBER PRIMARY KEY,\r

      \    email VARCHAR2(100) NOT NULL UNIQUE,\r

      \    tipo_email VARCHAR2(20) NOT NULL CHECK (tipo_email IN ('Personal',
      'Trabajo', 'Academico')),\r

      \    id_cliente NUMBER NOT NULL,\r

      \    CONSTRAINT fk_cliente_email FOREIGN KEY (id_cliente)\r

      \        REFERENCES cliente(id_cliente)\r

      );\r

      \r

      CREATE TABLE telefono_cliente (\r

      \    id_telefono NUMBER PRIMARY KEY,\r

      \    numero_telefono VARCHAR2(20) NOT NULL UNIQUE,\r

      \    tipo_telefono VARCHAR2(20) NOT NULL \r

      \        CHECK (tipo_telefono IN ('Personal', 'Residencial', 'Conyugal',
      'Familiar')),\r

      \    id_cliente NUMBER NOT NULL,\r

      \    FOREIGN KEY (id_cliente)\r

      \        REFERENCES cliente(id_cliente)\r

      );\r

      \r

      CREATE TABLE prestamo (\r

      \    id_prestamo NUMBER PRIMARY KEY,\r

      \    id_cliente NUMBER NOT NULL,\r

      \    id_tipo_prestamo NUMBER NOT NULL,\r

      \    num_prestamo VARCHAR2(20) NOT NULL UNIQUE,\r

      \    fecha_aprobacion DATE NOT NULL,\r

      \    monto_aprobado NUMBER NOT NULL\r

      \        CHECK (monto_aprobado > 0),\r

      \    tasa_interes NUMBER NOT NULL\r

      \        CHECK (tasa_interes >= 0 AND tasa_interes <= 100),\r

      \    letra_mensual NUMBER NOT NULL\r

      \        CHECK (letra_mensual > 0),\r

      \    monto_pagado NUMBER NOT NULL,\r

      \    fecha_pago DATE,\r

      \r

      \    CONSTRAINT fk_cliente_prestamo FOREIGN KEY (id_cliente)\r

      \        REFERENCES cliente(id_cliente),\r

      \    CONSTRAINT fk_tipo_prestamo FOREIGN KEY (id_tipo_prestamo)\r

      \        REFERENCES tipo_prestamo(id_tipo_prestamo) \r

      );\r\n"
    languageId: oracle-sql
  - kind: 1
    value: CREAR SECUENCIA PARA LAS ID
    languageId: markdown
  - kind: 2
    value: "CREATE SEQUENCE seq_id_profesion START WITH 1 INCREMENT BY 1 NOCYCLE;
      --TABLA PROFESION\r

      CREATE SEQUENCE seq_id_cliente START WITH 1 INCREMENT BY 1 NOCYCLE;
      --TABLA CLIENTE\r

      CREATE SEQUENCE seq_id_email START WITH 1 INCREMENT BY 1 NOCYCLE; --TABLA
      EMAIL\r

      CREATE SEQUENCE seq_id_telefono START WITH 1 INCREMENT BY 1 NOCYCLE;
      --TABLA TELEFONO\r

      CREATE SEQUENCE seq_id_prestamo START WITH 1 INCREMENT BY 1 NOCYCLE;
      --TABLA PRESTAMO\r

      CREATE SEQUENCE seq_id_tipo_prestamo START WITH 1 INCREMENT BY 1 NOCYCLE;
      --TABLA TIPO_PRESTAMO"
    languageId: oracle-sql
  - kind: 1
    value: INSERTAR DATOS
    languageId: markdown
  - kind: 2
    value: "-- DELETE INSERTS\r

      \r

      DELETE FROM prestamo;\r

      DELETE FROM telefono_cliente;\r

      DELETE FROM email;\r

      DELETE FROM cliente;\r

      DELETE FROM tipo_prestamo;\r

      DELETE FROM profesion;\r

      \r

      -- DROP SECUENCES\r

      DROP SEQUENCE seq_id_profesion;\r

      DROP SEQUENCE seq_id_cliente;\r

      DROP SEQUENCE seq_id_email;\r

      DROP SEQUENCE seq_id_telefono;\r

      DROP SEQUENCE seq_id_prestamo;\r

      DROP SEQUENCE seq_id_tipo_prestamo;\r

      \r

      CREATE SEQUENCE seq_id_profesion START WITH 1 INCREMENT BY 1 NOCYCLE;\r

      CREATE SEQUENCE seq_id_cliente START WITH 1 INCREMENT BY 1 NOCYCLE;\r

      CREATE SEQUENCE seq_id_email START WITH 1 INCREMENT BY 1 NOCYCLE;\r

      CREATE SEQUENCE seq_id_telefono START WITH 1 INCREMENT BY 1 NOCYCLE;\r

      CREATE SEQUENCE seq_id_prestamo START WITH 1 INCREMENT BY 1 NOCYCLE;\r

      CREATE SEQUENCE seq_id_tipo_prestamo START WITH 1 INCREMENT BY 1
      NOCYCLE;\r

      \r

      COMMIT;\r

      \r

      -- =========================\r

      -- INSERCIONES PROFESION\r

      -- =========================\r

      \r

      INSERT INTO profesion (id_profesion, nombre_profesion)\r

      VALUES (seq_id_profesion.NEXTVAL, 'Ingeniero de Software');\r

      \r

      INSERT INTO profesion (id_profesion, nombre_profesion)\r

      VALUES (seq_id_profesion.NEXTVAL, 'Contador');\r

      \r

      INSERT INTO profesion (id_profesion, nombre_profesion)\r

      VALUES (seq_id_profesion.NEXTVAL, 'Administrador');\r

      \r

      INSERT INTO profesion (id_profesion, nombre_profesion)\r

      VALUES (seq_id_profesion.NEXTVAL, 'Abogado');\r

      \r

      INSERT INTO profesion (id_profesion, nombre_profesion)\r

      VALUES (seq_id_profesion.NEXTVAL, 'Docente');\r

      \r

      -- =========================\r

      -- INSERCIONES TIPO_PRESTAMO\r

      -- =========================\r

      \r

      INSERT INTO tipo_prestamo (id_tipo_prestamo, nombre_tipo_prestamo)\r

